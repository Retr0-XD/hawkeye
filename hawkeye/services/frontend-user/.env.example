# Example environment for the Hawkeye User Console (frontend-user).
# Copy to `.env` and fill in. NEVER commit the real `.env` (it contains the
# OAuth client secret). The `.env` is git-ignored.
#
# NOTE: the OAuth client is a STANDARD "Web application" client ID. The token
# exchange requires the client_secret (bundled into the SPA by nature of the
# flow). For a hobby project this is acceptable; see SECURITY_NOTES.md.
VITE_GOOGLE_CLIENT_ID=__REPLACE_WITH_YOUR_WEB_CLIENT_ID__.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_SECRET=__REPLACE_WITH_YOUR_CLIENT_SECRET__
VITE_API_BASE=https://hawkeye-api-78803747777.us-central1.run.app
